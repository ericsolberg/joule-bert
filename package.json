{
  "name": "joule-bert",
  "private": true,
  "version": "0.0.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "docker:preview": "docker run --rm -p 8080:8080 ericsolberg/joule-bert:latest",
    "docker:build": "docker build --platform linux/amd64 -t ericsolberg/joule-bert:$npm_package_version -t ericsolberg/joule-bert:latest .",
    "docker:push": "docker push ericsolberg/joule-bert:$npm_package_version && docker push ericsolberg/joule-bert:latest",
    "kyma:update": "kubectl -n joule-bert set image deployment/joule-bert joule-bert=ericsolberg/joule-bert:$npm_package_version && kubectl -n joule-bert rollout status deployment/joule-bert",
    "deploy": "npm run docker:build && npm run docker:push && npm run kyma:update"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5"
  }
}
